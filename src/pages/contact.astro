---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import carolinePortrait from '../assets/pricing/caroline-portrait.jpg';
---

<Layout title="Contact — Caroline Gibson Photography">
  <section class="contact-section">
    <div class="contact-text">
      <h1>Get in touch.</h1>
      <p>
        I'm so happy you are considering me to capture these beautiful moments of life. I would love
        to be a part of it! Once you submit this contact form, I'll be in touch within 24 hours.
        I can't wait to tell your story, capture moments, and just get to hang out with amazing people!
      </p>
      <a href="#form" class="btn-outline">Contact Form</a>
    </div>
    <div class="contact-image">
      <Image
        src={carolinePortrait}
        alt="Caroline Gibson holding a camera"
        width={1600}
        height={2000}
        quality={100}
      />
    </div>
  </section>

  <section id="form" class="form-section">
    <div class="form-wrapper">
      <h2>Let's Chat</h2>
      <p class="form-intro">Fill out the details below and I'll get back to you within 24 hours.</p>

      <form id="contactForm">
        <div class="form-group">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required />
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required />
        </div>

        <div class="form-group">
          <label for="message">Tell me about your vision</label>
          <textarea id="message" name="message" rows="6" required></textarea>
        </div>

        <button type="submit" class="btn-outline">Send Message</button>
        <p id="formStatus"></p>
      </form>
    </div>
  </section>
</Layout>

<style>
  .contact-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
    padding: 5rem 5vw;
    min-height: 80vh;
  }

  .contact-text h1 {
    font-family: 'Playfair Display', serif;
    font-size: 3rem;
    color: var(--color-dark-brown);
    margin-bottom: 1.5rem;
  }

  .contact-text p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-dark-brown);
    margin-bottom: 2rem;
    max-width: 480px;
  }

  .btn-outline {
    display: inline-block;
    border: 1px solid var(--color-dark-brown);
    color: var(--color-dark-brown);
    padding: 0.9rem 2.5rem;
    border-radius: 6px;
    font-size: 0.9rem;
    letter-spacing: 0.03em;
    transition: background 0.2s ease, color 0.2s ease;
    background: transparent;
    cursor: pointer;
    font-family: 'Jost', sans-serif;
  }

  .btn-outline:hover {
    background: var(--color-dark-brown);
    color: var(--color-cream);
  }

  .contact-image {
    overflow: hidden;
    border-radius: 4px;
  }

  .contact-image :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .form-section {
    padding: 6rem 5vw;
    background: var(--color-taupe, #e8e2d8);
  }

  .form-wrapper {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .form-wrapper h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    color: var(--color-dark-brown);
    margin-bottom: 0.75rem;
  }

  .form-intro {
    font-family: 'Jost', sans-serif;
    color: var(--color-dark-brown);
    margin-bottom: 2.5rem;
    font-size: 1rem;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    text-align: left;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  label {
    font-family: 'Jost', sans-serif;
    font-size: 0.85rem;
    letter-spacing: 0.03em;
    color: var(--color-dark-brown);
  }

  input,
  textarea {
    font-family: 'Jost', sans-serif;
    font-size: 1rem;
    padding: 0.9rem 1rem;
    border: 1px solid var(--color-dark-brown);
    border-radius: 4px;
    background: var(--color-cream);
    color: var(--color-dark-brown);
    resize: vertical;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--color-dark-brown);
    box-shadow: 0 0 0 1px var(--color-dark-brown);
  }

  #formStatus {
    font-family: 'Jost', sans-serif;
    font-size: 0.9rem;
    color: var(--color-dark-brown);
    margin-top: 0.5rem;
    min-height: 1.2rem;
  }

  @media (max-width: 768px) {
    .contact-section {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>

<script>
  const form = document.getElementById('contactForm');
  const status = document.getElementById('formStatus');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    status.textContent = 'Sending...';

    const formData = new FormData(form);
    const payload = {
      name: formData.get('name'),
      email: formData.get('email'),
      message: formData.get('message'),
    };

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!response.ok) throw new Error();

      status.textContent = 'Thank you! Your message has been sent.';
      form.reset();
    } catch {
      status.textContent = 'Something went wrong. Please try again or email directly.';
    }
  });
</script>
