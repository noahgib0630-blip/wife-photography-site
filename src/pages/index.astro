---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

import heroImage from '../assets/hero/hero-couple.jpg';
import carolinePortrait from '../assets/pricing/caroline-portrait.jpg';

const images = Object.values(
  import.meta.glob('/src/assets/portfolio/*.{jpg,jpeg,png,webp}', { eager: true })
).map((mod) => mod.default);
---

<Layout title="Caroline Gibson Photography">
  <main>
    <!-- Hero -->
    <section class="hero">
      <Image
        src={heroImage}
        alt="Engaged couple holding hands"
        width={1920}
        height={1080}
        quality={90}
        class="hero-image"
      />
      <div class="hero-overlay">
        <h1>Your Moments, Made Timeless</h1>
      </div>
    </section>

    <!-- Philosophy -->
    <section class="philosophy">
      <div class="philosophy-inner">
        <h2 class="philosophy-heading">Photographs that will last<br />for a lifetime</h2>
        <div class="philosophy-text">
          <p>When it comes to photography, I'm all about you. My goal is to make the experience warm, laid-back, and actually fun!</p>
          <p>I believe photos should mean something. They're not just for now, but for the future—for your loved ones to hold onto and remember you by. I'm here to capture both the big milestones and the quiet, in-between moments that make life so special.</p>
          <p>In a world where it's easy to focus on picture-perfect poses, I'm drawn to what's real. The raw, genuine moments that tell your story just as it is. These are the photos that will bring smiles, spark memories, and remind future generations of who you were.</p>
        </div>
      </div>
    </section>

    <!-- About -->
    <section class="about">
      <div class="about-inner">
        <div class="about-portrait">
          <Image src={carolinePortrait} alt="Caroline Gibson, photographer" width={400} height={400} quality={90} />
        </div>
        <div class="about-text">
          <h2>About your photographer</h2>
          <p>Hi, I'm Caroline — the person behind the camera! Photography is all about capturing your story in a way that feels authentic and true to you. My goal is to make every session relaxed, enjoyable, and yes, actually fun!</p>
          <p>I got my first camera at 15, and my little sister quickly became my go-to model. I had no idea what I was doing, but I was completely hooked! Fast forward a few years, and after graduating college with a degree in graphic design, I found myself working at a church. That's when I fell even more in love with photography, capturing moments every weekend with their camera. I eventually began leading a photography team, helping others grow their skills, and realized this was what I was meant to do. So, I took the leap and pursued photography full-time — and I haven't looked back since!</p>
        </div>
      </div>
    </section>

<!-- Masonry Gallery -->
<section class="gallery">
  <div class="gallery-grid">
    {images.map((img, index) => (
      <div class="gallery-item" data-index={index}>
        <Image src={img} alt="Photography by Caroline Gibson" width={800} quality={85} />
      </div>
    ))}
  </div>
</section>

<!-- Lightbox Overlay -->
<div class="lightbox" id="lightbox">
  <button class="lightbox-close" id="lightboxClose" aria-label="Close">&times;</button>
  <button class="lightbox-arrow lightbox-prev" id="lightboxPrev" aria-label="Previous">&#8249;</button>
  <img class="lightbox-image" id="lightboxImage" src="" alt="" />
  <button class="lightbox-arrow lightbox-next" id="lightboxNext" aria-label="Next">&#8250;</button>
</div>

    <!-- CTA -->
    <section class="cta">
      <h2>Want to make moments<br />into sweet memories?</h2>
      <p>Embrace the moment! Reach out today to book your photo session.</p>
      <a href="/contact" class="cta-button">Book Now!</a>
      <div class="social-icons">
        <a href="https://www.instagram.com/carolgibson.photo/" aria-label="Instagram" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="2" width="20" height="20" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
          </svg>
        </a>
        <a href="https://www.facebook.com/profile.php?id=61560908040397" aria-label="Facebook" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M15 3h-2a5 5 0 0 0-5 5v2H6v4h2v7h4v-7h3l1-4h-4V8a1 1 0 0 1 1-1h3z" />
          </svg>
        </a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 70vh;
    min-height: 500px;
    overflow: hidden;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.15);
  }

  .hero-overlay h1 {
    font-family: 'Playfair Display', serif;
    color: #fff;
    font-size: clamp(2rem, 5vw, 4.5rem);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0 2rem;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
  }

  .philosophy {
    background: var(--color-taupe);
    padding: 5rem 2rem;
  }

  .philosophy-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .philosophy-heading {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 2.2rem;
    line-height: 1.3;
    color: var(--color-dark-brown);
  }

  .philosophy-text p {
    font-family: var(--font-sans);
    color: var(--color-dark-brown);
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .about {
    background: var(--color-cream);
    padding: 5rem 2rem;
  }

  .about-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 3rem;
    align-items: center;
  }

  .about-portrait :global(img) {
    border-radius: 50%;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  .about-text h2 {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    margin-bottom: 1rem;
    color: var(--color-dark-brown);
  }

  .about-text p {
    font-family: var(--font-sans);
    line-height: 1.7;
    margin-bottom: 1rem;
    color: var(--color-dark-brown);
  }

  .gallery {
    padding: 0 2rem;
  }

  .gallery-grid {
    column-count: 4;
    column-gap: 1rem;
  }

  .gallery-item {
    margin-bottom: 1rem;
    cursor: pointer;
  }

  .gallery-item :global(img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 4px;
  }

  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }

  .lightbox.active {
    display: flex;
  }

  .lightbox-image {
    max-width: 88%;
    max-height: 88vh;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
  }

  .lightbox-close {
    position: absolute;
    top: 24px;
    right: 32px;
    background: none;
    border: none;
    color: #fff;
    font-size: 2.5rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }

  .lightbox-close:hover {
    opacity: 1;
  }

  .lightbox-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: #fff;
    font-size: 3.5rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.2s ease;
    padding: 0.5rem 1rem;
  }

  .lightbox-arrow:hover {
    opacity: 1;
  }

  .lightbox-prev {
    left: 12px;
  }

  .lightbox-next {
    right: 12px;
  }

  @media (max-width: 700px) {
    .lightbox-arrow {
      font-size: 2.5rem;
    }
    .lightbox-close {
      font-size: 2rem;
      top: 16px;
      right: 20px;
    }
  }

  .cta {
    text-align: center;
    padding: 5rem 2rem;
    background: var(--color-cream);
  }

  .cta h2 {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    color: var(--color-dark-brown);
    margin-bottom: 1rem;
  }

  .cta p {
    font-family: var(--font-sans);
    color: var(--color-dark-brown);
    margin-bottom: 2rem;
  }

  .cta-button {
    display: inline-block;
    padding: 0.9rem 2.2rem;
    border: 1px solid var(--color-dark-brown);
    color: var(--color-dark-brown);
    text-decoration: none;
    font-family: var(--font-sans);
    letter-spacing: 0.05em;
    transition: background 0.3s, color 0.3s;
  }

  .cta-button:hover {
    background: var(--color-dark-brown);
    color: var(--color-cream);
  }

  .social-icons {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
  }

  .social-icons a {
    color: var(--color-dark-brown);
  }

  .social-icons svg {
    width: 22px;
    height: 22px;
  }

  @media (max-width: 800px) {
    .philosophy-inner {
      grid-template-columns: 1fr;
    }

    .about-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .about-portrait {
      max-width: 200px;
      margin: 0 auto;
    }
  }

  @media (max-width: 1000px) {
    .gallery-grid {
      column-count: 3;
    }
  }

  @media (max-width: 700px) {
    .gallery-grid {
      column-count: 2;
    }
  }

  @media (max-width: 450px) {
    .gallery-grid {
      column-count: 2;
    }
  }
</style>

<script>
  const galleryItems = document.querySelectorAll('.gallery-item');
  const lightbox = document.getElementById('lightbox');
  const lightboxImage = document.getElementById('lightboxImage');
  const closeBtn = document.getElementById('lightboxClose');
  const prevBtn = document.getElementById('lightboxPrev');
  const nextBtn = document.getElementById('lightboxNext');

  let currentIndex = 0;
  const imageSources = Array.from(galleryItems).map(
    (item) => item.querySelector('img').src
  );

  function openLightbox(index) {
    currentIndex = index;
    lightboxImage.src = imageSources[currentIndex];
    lightbox.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.remove('active');
    document.body.style.overflow = '';
  }

  function showNext() {
    currentIndex = (currentIndex + 1) % imageSources.length;
    lightboxImage.src = imageSources[currentIndex];
  }

  function showPrev() {
    currentIndex = (currentIndex - 1 + imageSources.length) % imageSources.length;
    lightboxImage.src = imageSources[currentIndex];
  }

  galleryItems.forEach((item, index) => {
    item.addEventListener('click', () => openLightbox(index));
  });

  closeBtn.addEventListener('click', closeLightbox);
  nextBtn.addEventListener('click', showNext);
  prevBtn.addEventListener('click', showPrev);

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('active')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') showNext();
    if (e.key === 'ArrowLeft') showPrev();
  });
</script>
